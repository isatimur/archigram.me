# ArchiGram.ai Environment Variables
# Copy this file to .env and fill in your values

# Deployment modes:
# - Minimal (self-host): VITE_GEMINI_API_KEY only
# - Full (hosted or self-host): Add Firebase for auth + user diagram sync
# - Community gallery: Supabase remains optional unless you use the hosted gallery tables

# ===========================================
# REQUIRED: Google Gemini AI (all modes)
# ===========================================
# Get your API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ===========================================
# REQUIRED FOR AUTH: Firebase Google Auth
# ===========================================
# Create a Firebase web app, enable Authentication > Google provider,
# and copy the web app config values here.
VITE_FIREBASE_API_KEY=AIzaSyCA26n0s84MhrLBu6SnqsLn-tahRi3gff8
VITE_FIREBASE_AUTH_DOMAIN=newagent-ba506.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://newagent-ba506.firebaseio.com
VITE_FIREBASE_PROJECT_ID=newagent-ba506
VITE_FIREBASE_STORAGE_BUCKET=newagent-ba506.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1007672315550
VITE_FIREBASE_APP_ID=1:1007672315550:web:861e93e723d99ccbddb58f

# Next/Vercel equivalents; set these in Vercel Project Settings > Environment Variables.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyCA26n0s84MhrLBu6SnqsLn-tahRi3gff8
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=newagent-ba506.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://newagent-ba506.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=newagent-ba506
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=newagent-ba506.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1007672315550
NEXT_PUBLIC_FIREBASE_APP_ID=1:1007672315550:web:861e93e723d99ccbddb58f

# ===========================================
# OPTIONAL: Supabase (community gallery)
# ===========================================
# Required for community gallery/profile pages backed by existing Supabase tables.
# Auth and personal diagram sync now use Firebase.
# Create a project at: https://supabase.com/
# Find these in: Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your_supabase_anon_key_here

# ===========================================
# OPTIONAL: Analytics
# ===========================================
# Plausible Analytics domain (privacy-focused analytics)
VITE_PLAUSIBLE_DOMAIN=archigram.ai
# Google Analytics 4 measurement ID (via Firebase Analytics)
VITE_FIREBASE_MEASUREMENT_ID=G-VCGG421FRV

# ===========================================
# OPTIONAL: RAG (Enterprise Knowledge Base)
# ===========================================
# RAG service URL (for company-specific context)
VITE_RAG_URL=http://localhost:8000
# Enable RAG integration (set to 'true' to enable)
VITE_RAG_ENABLED=false

# RAG Backend Configuration (for docker-compose --profile rag)
# API key for document ingestion (required for ingest endpoint)
RAG_INGEST_API_KEY=your_secure_api_key_here
# Use cloud embeddings instead of local E5 model
RAG_USE_CLOUD_EMBEDDINGS=false
# Gemini API key for cloud embeddings (only if USE_CLOUD_EMBEDDINGS=true)
RAG_GEMINI_API_KEY=
# Logging level (DEBUG, INFO, WARNING, ERROR)
RAG_LOG_LEVEL=INFO
# Maximum file size for ingestion in MB
RAG_MAX_FILE_SIZE_MB=10
# Search timeout in seconds
RAG_SEARCH_TIMEOUT_SEC=5
# CORS origins (comma-separated)
RAG_CORS_ORIGINS=http://localhost:3000
# Parser mode: "lightweight" (pypdf, default) or "docling" (rich multi-format)
RAG_PARSER_MODE=lightweight
# Enable OCR for scanned PDFs (docling mode only)
RAG_DOCLING_OCR_ENABLED=false
# Enable table structure extraction (docling mode only)
RAG_DOCLING_TABLE_STRUCTURE=true

# ===========================================
# OPTIONAL: Email (Resend)
# ===========================================
# For diagram sharing invitations, welcome emails, and newsletters
# Get your API key from: https://resend.com/
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=ArchiGram.ai <noreply@archigram.ai>
# Supabase service role key (for server-side newsletter operations)
# Find in: Supabase Dashboard > Settings > API > service_role key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ===========================================
# CLI & MCP SERVER
# ===========================================
# Hosted API URL (CLI/MCP use this when GEMINI_API_KEY is not set)
# ARCHIGRAM_API_URL=https://archigram.me
# For local generation in CLI/MCP (same as VITE_GEMINI_API_KEY)
# GEMINI_API_KEY=your_gemini_api_key_here

# ===========================================
# DEVELOPMENT
# ===========================================
# Enable debug logging (set to 'true' to enable)
# VITE_DEBUG=false
